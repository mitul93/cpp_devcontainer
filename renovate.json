{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "mode": "full",
    "customManagers": [
        {
            "customType": "regex",
            "fileMatch": [
                "(^|/)[a-zA-Z0-9_-]+_version\\.env$"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?=[^\\n]*\\bversioning=(?<versioning>\\S+))?[^\\n]*\\n\\w+=(?<currentValue>\\S+)"
            ]
        }
    ]
}